# ============================================================
# CoachStage 后端环境变量模板（容器内使用）
# 复制此文件为 .env 并填写真实值
# 此文件在 docker 容器中由 /app 目录加载
# ============================================================

# ---- 应用配置 ----
APP_NAME=coach-stage
APP_VERSION=1.0.0
DEBUG=true

# ---- 数据库（由 config.py 拼接出 DATABASE_URL）----
DB_USER=coach_user
DB_PASSWORD=change_me_in_production
DB_HOST=postgres
DB_PORT=5433
DB_NAME=coach_stage

# ---- Redis（由 config.py 拼接出 REDIS_URL）----
REDIS_PASSWORD=change_me_in_production
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---- 钉钉开放平台 ----
DINGTALK_APP_KEY=your_dingtalk_app_key
DINGTALK_APP_SECRET=your_dingtalk_app_secret
DINGTALK_CLIENT_ID=your_dingtalk_client_id
DINGTALK_CLIENT_SECRET=your_dingtalk_client_secret
DINGTALK_STREAM_TOPIC=/v1.0/im/bot/messages/get_by_app

# ---- LLM（OpenAI 兼容格式）----
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=your_llm_api_key
LLM_MODEL=deepseek-chat

# ---- ASR（本地 faster-whisper）----
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=int8_float16

# ---- TTS（MiniMax）----
TTS_API_KEY=your_tts_api_key
TTS_MODEL=speech-02-turbo
TTS_VOICE_ID=your_voice_id
MINIMAX_GROUP_ID=your_minimax_group_id
MINIMAX_VOICE=Calm_Woman

# ---- 外部知识库 RAG ----
RAG_API_URL=https://your-rag-service/api/search
RAG_API_KEY=your_rag_api_key

# ---- 跨域（开发环境放开，生产环境应限制具体域名）----
CORS_ORIGINS=["*"]
